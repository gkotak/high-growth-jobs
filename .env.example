# --- BACKEND SECRETS (Keep Private) ---
# Database
DATABASE_URL=postgresql://user:password@localhost:5432/highgrowthjobs

# AI / LLM (Raw API keys)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# LLM Registry — Change these 3 to swap the scraper's LLM provider
SCRAPER_LLM_MODEL=gemini-2.5-flash
SCRAPER_LLM_API_KEY=your_gemini_api_key_here
SCRAPER_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# LLM Observability (Langfuse)
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# Security
SECRET_KEY=generate_a_random_string_for_auth

# --- PUBLIC CONFIG (Safe for Dev) ---
LOG_LEVEL=INFO
ENVIRONMENT=development
